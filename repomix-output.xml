}

/// Handles `IDirect3DDevice9::SetSamplerState`.
pub fn handle_set_sampler_state(
    engine: &mut dyn wie_cpu::CpuEngine,
    state: &mut WinApiState,
) -> Result<WinApiHandlerResult> {
    let _this = engine
        .read_rcx()
