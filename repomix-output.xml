int add(int a, int b) { return a + b; }

int compute(int x, int y) {
  int t = x * y;
  int u = x + y;
  if (t > u) {
    return t - u;
  } else {
    return u - t;
  }
}

int factorial(int n) {
  if (n <= 1)
    return 1;
  return n * factorial(n - 1);
}

