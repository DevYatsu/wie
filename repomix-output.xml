/// Handles `KERNEL32.dll!FlsSetValue`.
pub fn handle_fls_set_value(
    engine: &mut dyn wie_cpu::CpuEngine,
    state: &mut WinApiState,
) -> Result<WinApiHandlerResult> {
    let index_raw = engine
        .read_rcx()
