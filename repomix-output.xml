        let old = mem
            .virtual_protect(base + 0x1000, 0x1000, protect::PAGE_READONLY)
            .expect("protect");
        assert_eq!(old, protect::PAGE_READWRITE);
        let mid = mem.virtual_query(base + 0x1000);
        assert_eq!(mid.state, MEM_COMMIT);
