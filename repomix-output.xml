    fn align_helpers() {
        assert_eq!(align_down(0x12345, 0x10000), 0x10000);
        assert_eq!(align_up(0x10001, 0x10000), 0x20000);
        assert_eq!(align_up(0x10000, 0x10000), 0x10000);
    }

